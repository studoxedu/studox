# ── Web / desktop app (Vite) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Admin / migration scripts in scripts/ (Node process.env) ──
# These are secrets — never commit real values. Set them in your
# shell or a local .env (git-ignored) before running the scripts.
SUPABASE_PAT=your-supabase-personal-access-token
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password
